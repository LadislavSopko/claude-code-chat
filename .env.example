# Environment
NODE_ENV=development

# API Server
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://claude_chat:claude_chat@localhost:5432/claude_chat

# Auth — Better Auth + Google OAuth
ADMIN_EMAIL=your-admin@example.com
BETTER_AUTH_SECRET=generate-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API Key Seed (first run only)
SEED_API_KEY=generate-a-random-api-key

# Security
ALLOWED_ORIGINS=http://localhost:4200

# Rate Limiting (optional)
# REST_RATE_LIMIT_PER_MINUTE=100
# WS_MESSAGE_RATE_LIMIT_PER_MINUTE=30
# WS_CONNECT_RATE_LIMIT_PER_MINUTE=10
