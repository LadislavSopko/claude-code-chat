{
  "mcpServers": {
    
    "primeng": {
      "command": "node",
      "args": [
        "/home/laco/.local/mcp/primeng/node_modules/@primeng/mcp/dist/index.js"
      ]
    },
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "claude-chat": {
      "command": "bun",
      "args": ["src/client.ts"],
      "env": {
        "CLAUDE_CHAT_NAME": "default",
        "CLAUDE_CHAT_BROKER": "ws://localhost:4000"
      }
    },
    "lsai": {
      "command": "/home/laco/.lsai/run",
      "args": ["--stdio"]
    }
  }
}
