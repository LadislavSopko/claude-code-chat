{
  "name": "claude-code-chat",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "api:dev": "bun run --filter @claude-code-chat/api dev",
    "api:build": "bun run --filter @claude-code-chat/api build",
    "web:dev": "bun run --filter @claude-code-chat/web dev",
    "web:build": "bun run --filter @claude-code-chat/web build",

    "generate:api-client": "bash tools/generate-api-client.sh",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  }
}
