{
  "mcpServers": {
    
    "primeng": {
      "command": "node",
      "args": [
        "/home/laco/.local/mcp/primeng/node_modules/@primeng/mcp/dist/index.js"
      ]
    },
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
      },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--executable-path=/opt/chrome/linux-143.0.7499.169/chrome-linux64/chrome",
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--user-data-dir=/home/laco/claude-code-chat/.chrome-profile"
      ],
      "env": {
        "DISPLAY": ":0"
      }
    },
    "claude-chat": {
      "command": "/home/laco/.bun/bin/bun",
      "args": ["src/client.ts"],
      "env": {
        "CLAUDE_CHAT_NAME": "claude",
        "CLAUDE_CHAT_API_KEY": "dev-api-key-change-me",
        "CLAUDE_CHAT_URL": "ws://localhost:3000"
      }
    },
    "ui-ticket-mcp": {
      "command": "uvx",
      "args": ["ui-ticket-mcp"],
      "env": {
        "PROJECT_ROOT": "/home/laco/claude-code-chat",
        "REVIEW_PORT": "3210"
      }
    },
    "lsai": {
      "command": "/home/laco/.lsai/run",
      "args": ["--stdio"]
    }
  }
}
